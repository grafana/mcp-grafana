
# ============================================================
# OAuth2 Configuration for MCP Grafana Server (Token Forwarding)
# ============================================================
# Enable OAuth2 token validation for incoming requests.
export OAUTH2_ENABLED=true

# Keycloak OAuth2 provider URL for local testing via published docker-compose port.
export OAUTH2_PROVIDER_URL=http://localhost:8082/realms/mcp-grafana

# OAuth2 User Info endpoint used by MCP for token validation.
export OAUTH2_USERINFO_ENDPOINT=/protocol/openid-connect/userinfo

# Token cache TTL in seconds.
export OAUTH2_TOKEN_CACHE_TTL=300

# ============================================================
# OAuth2 Token Forwarding to Grafana (Active Configuration)
# ============================================================
# Enable forwarding validated incoming OAuth2 user tokens to Grafana.
export OAUTH2_TOKEN_FORWARD_TO_GRAFANA_ENABLED=true

# Active local mode: forward as Authorization: Bearer <validated-user-token>.
export OAUTH2_TOKEN_FORWARD_TO_GRAFANA_USE_CLOUD_HEADERS=false

# Inactive alternative (Grafana Cloud-style forwarding headers):
# Sends:
#   X-Access-Token: <service-token>
#   X-Grafana-Id: <validated-user-token>
# export OAUTH2_TOKEN_FORWARD_TO_GRAFANA_USE_CLOUD_HEADERS=true
# export GRAFANA_API_KEY=<grafana-service-token>

# Inactive legacy aliases (kept for compatibility; prefer names above):
# export OAUTH2_OBO_ENABLED=true
# export OAUTH2_OBO_USE_GRAFANA_HEADERS=false

# ============================================================
# Grafana Configuration
# ============================================================
export GRAFANA_URL=http://localhost:3000
export GRAFANA_ORG_ID=1

# Optional fallback for direct API access if no forwarded token is present.
# Keep commented for active token-forwarding mode.
# export GRAFANA_API_KEY=

# ============================================================
# Auth Proxy Configuration (Inactive for token-forwarding mode)
# ============================================================
# Keep disabled when using OAuth2 token forwarding to Grafana.
export GRAFANA_PROXY_AUTH_ENABLED=false

# Inactive fallback: enable only when testing Auth Proxy header impersonation mode.
# export GRAFANA_PROXY_AUTH_ENABLED=true
# export GRAFANA_PROXY_USER_HEADER=X-WEBAUTH-USER
# export GRAFANA_PROXY_EMAIL_HEADER=X-WEBAUTH-EMAIL
# export GRAFANA_PROXY_NAME_HEADER=X-WEBAUTH-NAME
# export GRAFANA_PROXY_ROLE_HEADER=X-WEBAUTH-ROLE

# ============================================================
# MCP Server Configuration
# ============================================================
export MCP_SERVER_MODE=sse
export MCP_SERVER_PORT=8080
export MCP_SERVER_ADDRESS=localhost:8080

# Disable proxied tools for per-request OAuth2 user contexts.
export MCP_DISABLE_PROXIED_TOOLS=true

# ============================================================
# Logging
# ============================================================
export LOG_LEVEL=debug

# ============================================================
# Usage
# ============================================================
# source .env.oauth2-forward-test
# go run ./cmd/mcp-grafana/main.go
