# ============================================================
# OAuth2 Configuration for MCP Grafana Server (Local Testing)
# ============================================================
# Enable OAuth2 token validation for all incoming requests
export OAUTH2_ENABLED=true

# Keycloak OAuth2 provider URL for local testing via published docker-compose port.
export OAUTH2_PROVIDER_URL=http://localhost:8082/realms/mcp-grafana

# OAuth2 User Info endpoint (OpenID-Connect standard - used for token validation)
# MCP uses the client's bearer token directly with this endpoint.
export OAUTH2_USERINFO_ENDPOINT=/protocol/openid-connect/userinfo

# Token cache TTL in seconds (reduce provider load with caching)
# After TTL expires, token will be re-validated against OAuth2 provider.
export OAUTH2_TOKEN_CACHE_TTL=300

# ============================================================
# Grafana Configuration with Auth Proxy (User-Centric Model)
# ============================================================
# Grafana URL (MCP relays requests through Auth Proxy with user headers)
# Local testing uses the published Grafana port from docker-compose.
export GRAFANA_URL=http://localhost:3001

export GRAFANA_ORG_ID=1

# Optional: Grafana API key for direct API access (backward compatibility)
# When OAuth2 + Auth Proxy is enabled, this is not required
# GRAFANA_API_KEY=

# ============================================================
# Auth Proxy Configuration (User Identity Headers)
# ============================================================
# Enable Auth Proxy header injection for per-user API calls to Grafana
# When enabled, MCP will add X-WEBAUTH-* headers to all Grafana requests
# using the authenticated user from the OAuth2 token.
export GRAFANA_PROXY_AUTH_ENABLED=true

# Header names for user identity (must match Grafana proxy config)
# These are standard Grafana Auth Proxy headers.
export GRAFANA_PROXY_USER_HEADER=X-WEBAUTH-USER
export GRAFANA_PROXY_EMAIL_HEADER=X-WEBAUTH-EMAIL
export GRAFANA_PROXY_NAME_HEADER=X-WEBAUTH-NAME
export GRAFANA_PROXY_ROLE_HEADER=X-WEBAUTH-ROLE

# ============================================================
# MCP Server Configuration (SSE Mode for HTTP)
# ============================================================
# Transport mode: "sse" for Server-Sent Events, "stdio" for stdin/stdout.
export MCP_SERVER_MODE=sse

# HTTP server bind address for local demo.
export MCP_SERVER_PORT=8080
export MCP_SERVER_ADDRESS=localhost:8080

# Disable proxied tools in user-centric OAuth2 mode
# Since each client request provides its own OAuth2 token, datasource discovery
# happens per-session on-demand rather than at server startup.
# This prevents 401 Unauthorized errors during server initialization.
export MCP_DISABLE_PROXIED_TOOLS=true

# ============================================================
# Logging Configuration (Optional)
# ============================================================
# Log level: debug, info, warn, error.
export LOG_LEVEL=debug

# ============================================================
# How to use this file:
# ============================================================
# 1. Automatic setup (recommended):
#    ./testdata/oauth2-setup.sh
#    (Starts Keycloak and Grafana with Auth Proxy)
#
# 2. Manual setup:
#    - Ensure Keycloak is running: http://localhost:8082
#    - Ensure Grafana Auth Proxy is enabled: http://localhost:3001
#
# 3. Use in terminal:
#    source .env.oauth2-test
#    go run ./cmd/mcp-grafana/main.go
#
# 4. Test the flow:
#    ./testdata/oauth2-test.sh test-flow john.doe password123
#
# User-Centric Model:
# - Client gets OAuth2 token from Keycloak
# - Client sends token to MCP in Authorization header
# - MCP validates token, extracts user identity
# - MCP injects X-WEBAUTH-* headers for Grafana Auth Proxy
# - Grafana treats requests as the authenticated user
# ============================================================
