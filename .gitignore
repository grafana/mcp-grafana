# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.DS_Store
.vscode/
.env
.cursor/

# Local Claude Code session artifacts. Shared skills (.claude/skills/)
# stay tracked; the lockfile and any other transient session state
# do not.
.claude/scheduled_tasks.lock

# Virtual environments
.venv
.envrc

# Git worktrees
.worktrees/

# Superpowers agent artifacts (implementation plans, etc.)
docs/superpowers/

# Local Go build artifacts. The tilde-suffixed variants are emitted by
# `go build -o <name>~` and by editors that write to <name>~ before
# atomic rename — both of which can leave a tracked binary behind on
# Windows if the build was interrupted.
/bin/
/mcp-grafana
/mcp-grafana.exe
/mcp-grafana.exe~
/mcp-grafana~
/mock_oidc
/mock_oidc.exe
/mock_oidc.exe~
/mock_oidc~
*.exe~
